# ============================================================
# Battery State Estimator — Dashboard Environment Variables
# LOCAL:      copy this file to .env and fill in values
# PRODUCTION: set these in the Render Dashboard → Environment tab.
#             NEVER commit .env with real credentials to Git.
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
# LOCAL:      mongodb://localhost:27017/
# PRODUCTION: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=battery_estimation_db
MONGODB_READINGS_COLLECTION=readings
MONGODB_STATE_COLLECTION=sim_state

# ── Flask server ──────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=False

# ── Battery State Estimator Physics Engine URL ─────────────────
# LOCAL:      http://localhost:8000
# PRODUCTION: https://battery-state-estimator-physics.onrender.com
SIMULATOR_URL=https://battery-state-estimator-physics.onrender.com

# ── File paths ────────────────────────────────────────────────
MODEL_PATH=model_rc.pkl
# NOTE: After first deploy, run POST /api/train to populate MongoDB with a
# fresh trained ESN model. The local model_rc.pkl is a fallback only.

# ── Battery simulator ─────────────────────────────────────────
SIMULATION_STEP_DELAY=1.0

# ── Telemetry storage ─────────────────────────────────────────
TELEMETRY_RESPONSE_LIMIT=150
TELEMETRY_FALLBACK_LIMIT=1000
