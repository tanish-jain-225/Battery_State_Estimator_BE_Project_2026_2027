# Battery State Estimator - Dashboard
# Copy this file to .env for local overrides.
# Never commit .env files with real credentials.

MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=battery_estimation_db
MONGODB_READINGS_COLLECTION=readings
MONGODB_STATE_COLLECTION=sim_state

PORT=5000
FLASK_DEBUG=False
SIMULATOR_URL=http://localhost:8000

MODEL_PATH=model_rc.pkl
CSV_PATH=datasets/training_ev_battery_dataset_multiclass.csv

# Remote training dataset (Google Sheets or any public CSV URL).
# Use this to enable ESN retraining in production (serverless) environments
# where no local CSV file is available.
#
# Google Sheets setup:
#   1. Open your sheet → File → Share → Publish to web
#   2. Choose "Sheet 1" and format "Comma-separated values (.csv)" → Publish
#   3. Paste the generated URL below (it will end with ...output=csv or ...format=csv)
#
# CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv
CSV_URL=

SIMULATION_STEP_DELAY=1.0
TELEMETRY_RESPONSE_LIMIT=150
GRAPH_SLICE_LIMIT=120
TELEMETRY_FALLBACK_LIMIT=1000

FEATURE_ROLLING_WINDOW=5
DATASET_TIME_STEP=0.001
ESN_WASHOUT_STEPS=50
ESN_PRIMING_STEPS=50
