# Battery State Estimator — Physics Engine environment variables
# LOCAL: copy this file to .env and fill in values for local development.
# PRODUCTION (Render): set these in the Render Dashboard → Environment tab.
#   NEVER commit .env with real credentials to Git.
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=battery_estimation_db
MONGODB_READINGS_COLLECTION=readings
MONGODB_STATE_COLLECTION=sim_state
PORT=8000
FLASK_DEBUG=False
SIMULATION_STEP_DELAY=1.0