# Battery State Estimator - Hardware ESN classifier
# Copy this file to .env for local training/export overrides.

CSV_FILE=original_ev_battery_dataset_multiclass.csv
WEIGHTS_HEADER=esn_classifier_weights.h

ESN_N_INPUTS=3
ESN_N_RESERVOIR=50
ESN_N_OUTPUTS=3
ESN_SPECTRAL_RADIUS=0.95
ESN_LEAK_RATE=0.3
ESN_INPUT_SCALING=1.0
ESN_RIDGE_PARAM=1e-4
ESN_SPARSITY=0.85
ESN_WASHOUT=50

TEMP_NORMAL_MAX=35.0
TEMP_WARNING_MAX=45.0
